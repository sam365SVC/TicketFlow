# Copiar a .env (gitignored) y completar segun el entorno. Si no se define nada,
# docker-compose usa los defaults indicados en cada variable.

# --- Booking.API: usuario Admin inicial (seed) ---
# Se crea automaticamente al arrancar booking-api si no existe. Cambiar antes de un entorno real.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@ticketflow.local
ADMIN_PASSWORD=admin
